{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Firmware App",
            "command": "/usr/bin/clang",
            "args": [
                "-g",
                "${workspaceFolder}/firmware_app/src/main.c",
                "${workspaceFolder}/firmware_app/src/app.c",
                "${workspaceFolder}/firmware_app/src/comm/i2c_mock.c",
                "${workspaceFolder}/firmware_app/src/comm/tcp_mock.c",
                "${workspaceFolder}/firmware_app/src/common/circular_queue.c",
                "${workspaceFolder}/firmware_app/src/filters/iir_filter.c",
                "${workspaceFolder}/firmware_app/src/sensors/accelerometer.c",
                "-I${workspaceFolder}/firmware_app/src/",
                "-I${workspaceFolder}/firmware_app/src/comm",
                "-I${workspaceFolder}/firmware_app/src/filters",
                "-I${workspaceFolder}/firmware_app/src/sensors",
                "-I${workspaceFolder}/firmware_app/src/common",
                "-Wno-attributes",
                "-o",
                "${workspaceFolder}/firmware_app/build/firmware_app"
            ],
            "problemMatcher": ["$gcc"],
        },
        {
            "type": "cppbuild",
            "label": "Test Firmware App",
            "command": "/usr/bin/clang",
            "args": [
                "-g",
                "${workspaceFolder}/firmware_app/test/test_app.c",
                "${workspaceFolder}/firmware_app/src/app.c",
                "${workspaceFolder}/firmware_app/src/comm/i2c_mock.c",
                "${workspaceFolder}/firmware_app/src/comm/tcp_mock.c",
                "${workspaceFolder}/firmware_app/src/common/circular_queue.c",
                "${workspaceFolder}/firmware_app/src/filters/iir_filter.c",
                "${workspaceFolder}/firmware_app/src/sensors/accelerometer.c",
                "${workspaceFolder}/firmware_app/test/Unity/src/unity.c",
                "-I${workspaceFolder}/firmware_app/test/Unity/src",
                "-I${workspaceFolder}/firmware_app/src/",
                "-I${workspaceFolder}/firmware_app/src/comm",
                "-I${workspaceFolder}/firmware_app/src/filters",
                "-I${workspaceFolder}/firmware_app/src/sensors",
                "-I${workspaceFolder}/firmware_app/src/common",
                "-Wno-attributes",
                "-o",
                "${workspaceFolder}/firmware_app/test/build/test_firmware_app"
            ],
            "problemMatcher": ["$gcc"],
        },
        {
            "label": "Build test_accelerometer",
            "type": "cppbuild",
            "command": "/usr/bin/clang",
            "args": [
                "-g",
                "${workspaceFolder}/firmware_app/test/test_accelerometer.c",
                "${workspaceFolder}/firmware_app/src/sensors/accelerometer.c",
                "${workspaceFolder}/firmware_app/src/comm/i2c_mock.c",
                "${workspaceFolder}/firmware_app/test/Unity/src/unity.c",
                "-I${workspaceFolder}/firmware_app/test/Unity/src",
                "-I${workspaceFolder}/firmware_app/src",
                "-I${workspaceFolder}/firmware_app/src/comm",
                "-I${workspaceFolder}/firmware_app/src/filters",
                "-I${workspaceFolder}/firmware_app/src/sensors",
                "-I${workspaceFolder}/firmware_app/src/common",
                "-Wno-attributes",
                "-o", "${workspaceFolder}/firmware_app/test/build/test_accelerometer"
            ],
            "dependsOn": ["Build Firmware App"],
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Build test_queue",
            "type": "cppbuild",
            "command": "/usr/bin/clang",
            "args": [
                "-g",
                "${workspaceFolder}/firmware_app/test/test_circular_queue.c",
                "${workspaceFolder}/firmware_app/src/common/circular_queue.c",
                "${workspaceFolder}/firmware_app/test/Unity/src/unity.c",
                "-I${workspaceFolder}/firmware_app/test/Unity/src",
                "-I${workspaceFolder}/firmware_app/src",
                "-I${workspaceFolder}/firmware_app/src/comm",
                "-I${workspaceFolder}/firmware_app/src/filters",
                "-I${workspaceFolder}/firmware_app/src/sensors",
                "-I${workspaceFolder}/firmware_app/src/common",
                "-Wno-attributes",
                "-o", "${workspaceFolder}/firmware_app/test/build/test_circular_queue"
            ],
            "dependsOn": ["Build Firmware App"],
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Build test_sample",
            "type": "cppbuild",
            "command": "/usr/bin/clang",
            "args": [
                "-g",
                "${workspaceFolder}/firmware_app/test/test_sample.c",
                "${workspaceFolder}/firmware_app/test/Unity/src/unity.c",
                "-I${workspaceFolder}/firmware_app/test/Unity/src",
                "-I${workspaceFolder}/firmware_app/src",
                "-I${workspaceFolder}/firmware_app/src/comm",
                "-I${workspaceFolder}/firmware_app/src/filters",
                "-I${workspaceFolder}/firmware_app/src/sensors",
                "-I${workspaceFolder}/firmware_app/src/common",
                "-Wno-attributes",
                "-o", "${workspaceFolder}/firmware_app/test/build/test_sample"
            ],
            "dependsOn": ["Build Firmware App"],
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": true }
        }
    ],
    "version": "2.0.0"
}