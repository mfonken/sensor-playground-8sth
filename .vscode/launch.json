{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Client App (Python)",
            "type": "debugpy",
            "request": "launch",
            "program": "client_app/client_app.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Firmware App (C)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/firmware_app/build/firmware_app",
